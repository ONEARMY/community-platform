{
  "compilerOptions": {
    "composite": true,
    "target": "es2023",
    "jsx": "react-jsx",
    "module": "ESNext",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "include": ["src", "types"]
}
