{
  "compilerOptions": {
    "composite": true,
    "target": "es2023",
    "jsx": "react-jsx",
    "module": "ESNext",
    "rootDir": "./src",
    "moduleResolution": "bundler",
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true,
    "paths": {
      "oa-shared": ["../../shared/index.ts"],
      "oa-shared/*": ["../../shared/*"],
      "oa-themes": ["../themes/src/index.ts"],
      "oa-themes/*": ["../themes/src/*"]
    }
  },
  "include": ["src", "types"],
  "references": [{ "path": "../../shared" }, { "path": "../themes" }]
}
