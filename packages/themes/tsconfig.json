{
  "compilerOptions": {
    "composite": true,
    "target": "es2021",
    "jsx": "react-jsx",
    "module": "ES6",
    "moduleResolution": "node",
    "rootDir": "./src",
    "declaration": true,
    "outDir": "./dist",
    "esModuleInterop": true,
    "forceConsistentCasingInFileNames": true,
    "strict": true,
    "strictPropertyInitialization": false,
    "skipLibCheck": true
  },
  "include": ["src", "src/types"]
}
